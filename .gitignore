# =============================================================================
# Splunk-Environment-Lab — what NOT to commit
# =============================================================================
# GitHub rejects any single file > 100 MB and warns at 50 MB. The BOTSv1
# dataset is 6 GB compressed / ~9 GB extracted, with individual bucket
# files up to 3 GB — none of it belongs in git.
#
# Note: .gitignore does NOT support inline comments. Anything after a
# pattern is treated as part of the pattern. All comments live on their
# own lines below.

# -----------------------------------------------------------------------------
# BOTS datasets (whole tree). Keep the per-version directory structure in
# git so setup scripts have somewhere to drop downloads, but block all
# extracted data and archives.
# -----------------------------------------------------------------------------
bots-data/**
!bots-data/README.md
!bots-data/botsv1/
!bots-data/botsv2/
!bots-data/botsv3/
!bots-data/botsv1/.gitkeep
!bots-data/botsv2/.gitkeep
!bots-data/botsv3/.gitkeep

# Any other bots* folder a user might create
bots-data-*/**

# -----------------------------------------------------------------------------
# attack_data micro-CTF raw logs (per-family, downloaded by setup.sh).
# Keep the small yml metadata + manifest + docs, block the actual log
# files (10-75 MB each, ~330 MB total).
# -----------------------------------------------------------------------------
attack-data/**/*.log
attack-data/**/*.json
!attack-data/manifest.json
!attack-data/README.md

# -----------------------------------------------------------------------------
# Official Splunk BOTS CTF question/answer/hint data. This is Splunk's
# proprietary content, requested directly from Splunk (not ours to publish) —
# see docker/CTF_SCOREBOARD.md for how to request it via email. Keep the
# vN_official/README.md placeholder in git, block whatever real content lands
# inside the folder.
# -----------------------------------------------------------------------------
docker/ctf_seed_data/v1_official/botsv1content/
docker/ctf_seed_data/v2_official/botsv2content/
docker/ctf_seed_data/v3_official/botsv3content/

# -----------------------------------------------------------------------------
# Splunk artefacts — bucket internals, app packages, installers
# -----------------------------------------------------------------------------

# Index files (often hundreds of MB)
*.tsidx
# Splunk bucket archives
*.bucket
# Raw event journal inside buckets
journal.gz
# Bucket rawdata folders, wherever they appear
rawdata/
# Splunk app packages
*.spl
# Forwarder + Splunk installers (the one at repo root is ~120 MB)
splunkforwarder-*
splunk-*.tgz
splunk-*.zip
splunk-*.msi

# Local Splunk state if anyone runs Splunk directly on the host
var/lib/splunk/

# -----------------------------------------------------------------------------
# Generic archives & installers — GitHub-hostile
# -----------------------------------------------------------------------------
*.tgz
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.rar
*.iso
*.dmg
*.deb
*.rpm
*.msi
*.exe

# -----------------------------------------------------------------------------
# Secrets & credentials
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.pfx
*.p12
credentials.json

# Splunk leaks $7$ hashes into these on first boot — never commit
**/passwords.conf
# server.conf contains pass4SymmKey
**/server.conf

# CTF scoreboard privileged service-account credentials — generated by
# setup.sh from scoreboard_controller.config.example, never commit the real one
**/scoreboard_controller.config

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# -----------------------------------------------------------------------------
# Node (just in case)
# -----------------------------------------------------------------------------
node_modules/
dist/
build/

# -----------------------------------------------------------------------------
# AI agent skills (installed locally via caveman/skills-cli, e.g. `npx skills`)
# Machine-local tooling, not project source.
# -----------------------------------------------------------------------------
.agents/skills/
.claude/skills/
agent/skills/
skills-lock.json

# -----------------------------------------------------------------------------
# Proprietary workshop materials — Splunk-provided PDFs, not for redistribution.
# The exercises in challenges/Bots Training/ reference these
# decks but the decks themselves stay out of git.
# -----------------------------------------------------------------------------
challenges/Bots Training/Enterprise Security 8.3 Hands-On Lab Gude.pdf
challenges/Bots Training/MD101_For BOTS_Hands-On_Workshop.pdf

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.tmp

# -----------------------------------------------------------------------------
# Logs at repo root only — keep generated samples in subfolders if needed
# -----------------------------------------------------------------------------
/*.log
